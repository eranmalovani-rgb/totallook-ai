# =============================================================================
# TotalLook.ai — Railway Environment Variables
# Copy this to .env and fill in your values
# =============================================================================

# --- Required ---

# Database (Railway MySQL - use the public URL from Railway dashboard)
DATABASE_URL=mysql://root:PASSWORD@HOST:PORT/railway

# JWT Secret for session cookies (generate a random 64-char string)
JWT_SECRET=your-random-secret-here-at-least-32-characters-long

# OpenAI API Key for AI analysis (GPT-4o + DALL-E 3)
OPENAI_API_KEY=sk-proj-your-openai-key-here

# --- Storage (Cloudflare R2 recommended, ~$0.015/GB/month) ---

R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=totallook
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# --- Or use any S3-compatible provider ---
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY_ID=your-key
# S3_SECRET_ACCESS_KEY=your-secret
# S3_BUCKET_NAME=totallook
# S3_PUBLIC_URL=https://your-bucket.s3.amazonaws.com

# --- WhatsApp Integration (optional) ---

WHATSAPP_TOKEN=your-meta-whatsapp-token
WHATSAPP_PHONE_ID=your-phone-id
WHATSAPP_VERIFY_TOKEN=your-verify-token

# --- Site Configuration ---

SITE_URL=https://totallook.ai
VITE_APP_URL=https://totallook.ai
NODE_ENV=production

# --- Optional ---

# Owner email for notifications
OWNER_EMAIL=your@email.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# Twilio (for SMS, optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
